{
  "name": "weecommerce",
  "version": "1.0.0",
  "private": true,
  "description": "WeeCommerce company profile website — Next.js + Hono + PostgreSQL",
  "scripts": {
    "dev": "pnpm --filter @weecommerce/web dev & pnpm --filter @weecommerce/api dev",
    "build": "pnpm --filter @weecommerce/web build && pnpm --filter @weecommerce/api build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @weecommerce/web test:e2e",
    "db:migrate": "pnpm --filter @weecommerce/api db:migrate",
    "db:seed": "pnpm --filter @weecommerce/api db:seed",
    "docker:dev": "docker compose -f docker-compose.dev.yml up -d",
    "docker:dev:down": "docker compose -f docker-compose.dev.yml down"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
